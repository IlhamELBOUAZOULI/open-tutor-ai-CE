<script lang="ts">
  import { goto } from '$app/navigation';
  import { user } from '$lib/stores';
  import { onMount } from 'svelte';

  let loading = true;
  let activeTab = 'assignments';
  let assignments: any[] = [];
  let courses: any[] = [];
  let classrooms: any[] = [];
  let selectedPdf: { url: string; title: string } | null = null;

  // Rejoindre une classe
  let showJoinModal = false;
  let joinCode = '';
  let joinLoading = false;
  let joinError = '';
  let joinSuccess = '';

  const API = 'http://localhost:8080';

  // ── Auth ──────────────────────────────────────────────────
  function getToken(): string | null {
    try {
      const t = localStorage.getItem('token') || sessionStorage.getItem('token');
      if (t) return t.replace(/^"|"$/g, '');
    } catch (e) {}
    return null;
  }

  async function apiFetch(path: string, options: RequestInit = {}) {
    const t = getToken();
    const res = await fetch(`${API}${path}`, {
      ...options,
      headers: {
        'Content-Type': 'application/json',
        ...(t ? { Authorization: `Bearer ${t}` } : {}),
        ...(options.headers || {}),
      },
    });
    if (!res.ok) throw new Error(`${res.status}`);
    return res.json();
  }

  // ── Chargement des données ────────────────────────────────
  async function loadAll() {
    loading = true;

    // 1. Récupérer les classes de l'étudiant
    try {
      classrooms = await apiFetch('/api/v1/my-classrooms');
    } catch {
      classrooms = [];
    }

    const allAssignments: any[] = [];
    const allCourses: any[]     = [];

    // 2. Pour chaque classe, récupérer devoirs ET cours
    for (const classroom of classrooms) {
      const code = classroom.class_code || classroom.code;
      if (!code) continue;

      // Devoirs
      try {
        const a = await apiFetch(`/api/v1/classroom/${code}/assignments`);
        allAssignments.push(...(Array.isArray(a) ? a : []));
      } catch {}

      // Cours (fichiers uploadés par le prof)
      try {
        const c = await apiFetch(`/api/v1/classroom/${code}/courses`);
        allCourses.push(...(Array.isArray(c) ? c : []));
      } catch {}
    }

    assignments = allAssignments;
    courses     = allCourses;
    loading     = false;
  }

  // ── Rejoindre une classe ──────────────────────────────────
  async function joinClassroom() {
    if (!joinCode.trim()) { joinError = 'Veuillez entrer un code.'; return; }
    joinLoading = true;
    joinError   = '';
    joinSuccess = '';
    try {
      await apiFetch('/api/v1/join-classroom', {
        method: 'POST',
        body: JSON.stringify({ code: joinCode.trim().toUpperCase() }),
      });
      joinSuccess = '✅ Vous avez rejoint la classe avec succès !';
      joinCode = '';
      await loadAll();
      setTimeout(() => { showJoinModal = false; joinSuccess = ''; }, 2000);
    } catch (e: any) {
      joinError = 'Code invalide ou classe introuvable.';
    }
    joinLoading = false;
  }

  // ── Utilitaires ───────────────────────────────────────────
  function getDaysLeft(due_date: string): string {
    if (!due_date) return '';
    const diff = Math.ceil((new Date(due_date).getTime() - Date.now()) / 86400000);
    if (diff < 0)  return 'Expiré';
    if (diff === 0) return "Aujourd'hui";
    if (diff === 1) return 'Demain';
    return `${diff} jours`;
  }

  function getDaysClass(due_date: string): string {
    if (!due_date) return '';
    const diff = Math.ceil((new Date(due_date).getTime() - Date.now()) / 86400000);
    if (diff < 0)   return 'expired';
    if (diff <= 2)  return 'urgent';
    return 'ok';
  }

  function fileIcon(type: string): string {
    if (type === '.pdf')                      return '📄';
    if (['.doc', '.docx'].includes(type))     return '📝';
    if (['.ppt', '.pptx'].includes(type))     return '📊';
    return '📁';
  }

  function formatSize(bytes: number): string {
    if (!bytes) return '—';
    if (bytes < 1024)        return bytes + ' o';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' Ko';
    return (bytes / (1024 * 1024)).toFixed(1) + ' Mo';
  }

  // ── Viewer PDF ────────────────────────────────────────────
  function openPdf(url: string, title: string) {
    selectedPdf = { url, title };
  }
  function closePdf() { selectedPdf = null; }

  function getCourseFileUrl(course: any): string {
    const t = getToken();
    return `${API}/api/v1/courses/${course.id}/file${t ? `?token=${t}` : ''}`;
  }

  async function downloadFile(url: string, filename: string) {
    const t = getToken();
    try {
      const res = await fetch(url, {
        headers: t ? { Authorization: `Bearer ${t}` } : {},
      });
      const blob = await res.blob();
      const a    = document.createElement('a');
      a.href     = URL.createObjectURL(blob);
      a.download = filename || 'document';
      a.click();
      URL.revokeObjectURL(a.href);
    } catch {
      window.open(url, '_blank');
    }
  }

  // ── Lifecycle ─────────────────────────────────────────────
  onMount(async () => {
    if (!$user) { goto('/auth'); return; }
    if ($user.role !== 'user') { goto(`/${$user.role}`); return; }
    await loadAll();
  });
</script>

<!-- ═══════════════════════════════════════════════════════════
     STYLES
═══════════════════════════════════════════════════════════ -->
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  .dash { min-height: 100vh; background: #020b15; color: #cfe4f5; font-family: 'DM Sans', 'Segoe UI', sans-serif; }

  /* Header */
  .header { background: #030f1f; border-bottom: 1px solid #0b2d4e; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; height: 60px; position: sticky; top: 0; z-index: 100; }
  .logo { font-size: 1.3rem; font-weight: 800; color: #3b9eff; letter-spacing: -0.5px; }
  .logo span { color: #7ec8ff; }
  .user-badge { background: #041529; border: 1px solid #0b3a6e; border-radius: 20px; padding: 0.3rem 0.9rem; font-size: 0.82rem; color: #7ec8ff; }

  /* Layout */
  .layout { display: flex; min-height: calc(100vh - 60px); }

  /* Sidebar */
  .sidebar { width: 210px; background: #020d1a; border-right: 1px solid #0b2440; padding: 1rem 0; flex-shrink: 0; }
  .nav-item { display: flex; align-items: center; gap: 0.6rem; padding: 0.7rem 1.4rem; cursor: pointer; border-left: 3px solid transparent; font-size: 0.88rem; color: #3a6e99; font-weight: 500; transition: all 0.2s; }
  .nav-item:hover { background: #041829; color: #7ec8ff; }
  .nav-item.active { background: #041e38; color: #3b9eff; border-left-color: #3b9eff; }
  .nav-divider { margin: 0.5rem 1rem; border-top: 1px solid #0b2440; }
  .btn-join-sidebar { display: flex; align-items: center; gap: 0.6rem; padding: 0.7rem 1.4rem; cursor: pointer; border-left: 3px solid transparent; font-size: 0.88rem; color: #4caf50; font-weight: 600; transition: all 0.2s; width: 100%; background: none; border: none; }
  .btn-join-sidebar:hover { background: #052e16; border-left-color: #4caf50; }

  /* Main */
  .main { flex: 1; padding: 1.5rem 2rem; overflow-y: auto; }
  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.75rem; }
  .page-title { font-size: 1.6rem; font-weight: 700; color: #e8f4ff; }
  .page-sub { font-size: 0.82rem; color: #2a5f8f; margin-top: 0.2rem; }

  /* Boutons */
  .btn { padding: 0.45rem 0.9rem; border-radius: 8px; border: none; cursor: pointer; font-weight: 600; font-size: 0.82rem; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.35rem; font-family: inherit; white-space: nowrap; }
  .btn-join-main { background: #052e16; color: #4caf50; border: 1px solid #1b5e20; }
  .btn-join-main:hover { background: #063a1c; border-color: #4caf50; }
  .btn-pdf  { background: #041829; color: #7ec8ff; border: 1px solid #0b3a6e; }
  .btn-pdf:hover  { background: #052840; border-color: #3b9eff; color: #3b9eff; }
  .btn-dl   { background: #041829; color: #4caf50; border: 1px solid #1b5e20; }
  .btn-dl:hover   { background: #052e16; border-color: #4caf50; }
  .btn-submit { background: #1565c0; color: #e3f2fd; }
  .btn-submit:hover:not(:disabled) { background: #1976d2; }
  .btn-submit:disabled { background: #0b2440; color: #2a5f8f; cursor: not-allowed; }

  /* Stats */
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
  .stat { background: #030f1e; border: 1px solid #0b2440; border-radius: 10px; padding: 1rem; text-align: center; }
  .stat-num   { font-size: 1.8rem; font-weight: 800; color: #3b9eff; }
  .stat-label { font-size: 0.72rem; color: #2a5f8f; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 0.2rem; }

  /* Cards devoirs */
  .acard { background: #030f1e; border: 1px solid #0b2440; border-radius: 10px; padding: 1rem 1.25rem; display: flex; align-items: center; gap: 1rem; margin-bottom: 0.6rem; transition: border-color 0.2s; flex-wrap: wrap; }
  .acard:hover { border-color: #0b3a6e; }
  .ainfo { flex: 1; min-width: 0; }
  .atitle { font-weight: 600; color: #e8f4ff; margin-bottom: 0.2rem; font-size: 0.95rem; }
  .ameta { font-size: 0.78rem; color: #2a5f8f; display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 0.25rem; }

  /* Cards cours */
  .ccard { background: #030f1e; border: 1px solid #0b2440; border-radius: 12px; padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; transition: border-color 0.2s; }
  .ccard:hover { border-color: #0b3a6e; }
  .courses-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .course-icon { font-size: 2rem; }
  .course-name { font-weight: 700; font-size: 0.95rem; color: #e8f4ff; line-height: 1.4; }
  .course-desc { font-size: 0.8rem; color: #4a7fa8; line-height: 1.5; }
  .course-meta { font-size: 0.75rem; color: #2a5f8f; display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .course-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.25rem; }

  /* Badges */
  .deadline { display: inline-flex; align-items: center; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.72rem; font-weight: 700; white-space: nowrap; flex-shrink: 0; }
  .deadline.ok      { background: #041e38; color: #3b9eff;  border: 1px solid #0b3a6e; }
  .deadline.urgent  { background: #2d1a00; color: #ffb74d;  border: 1px solid #5d3a00; }
  .deadline.expired { background: #1a0505; color: #ef9a9a;  border: 1px solid #4a1010; }
  .ctag { display: inline-flex; align-items: center; gap: 3px; padding: 0.12rem 0.45rem; border-radius: 6px; font-size: 0.7rem; font-weight: 600; background: #041829; color: #3b9eff; border: 1px solid #0b3a6e; margin-right: 0.25rem; }
  .badge-module { background: #1e1b4b; color: #818cf8; border: 1px solid #3730a3; font-size: 0.7rem; border-radius: 20px; padding: 0.15rem 0.5rem; }

  /* Welcome */
  .welcome { background: #030f1e; border: 1px solid #0b2440; border-left: 4px solid #3b9eff; border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; font-size: 0.9rem; color: #7ec8ff; }
  .welcome strong { color: #e8f4ff; }

  /* Empty / Spin */
  .empty { text-align: center; padding: 3rem; color: #1a4a6e; font-size: 0.9rem; line-height: 2; }
  .spin  { display: flex; align-items: center; justify-content: center; height: 200px; color: #2a5f8f; font-size: 1.1rem; }

  /* ── Modal rejoindre ── */
  .modal-backdrop { position: fixed; inset: 0; background: rgba(2,11,21,0.88); z-index: 999; display: flex; align-items: center; justify-content: center; }
  .modal { background: #020d1a; border: 1px solid #0b3a6e; border-radius: 16px; padding: 2rem; width: 100%; max-width: 400px; }
  .modal-title { font-size: 1.2rem; font-weight: 700; color: #e8f4ff; margin-bottom: 0.4rem; }
  .modal-sub   { font-size: 0.82rem; color: #2a5f8f; margin-bottom: 1.5rem; }
  .code-input  { width: 100%; background: #030f1e; border: 1px solid #0b3a6e; border-radius: 10px; padding: 0.85rem 1rem; font-size: 1.4rem; font-weight: 800; color: #3b9eff; text-align: center; letter-spacing: 0.4rem; text-transform: uppercase; outline: none; transition: border-color 0.2s; }
  .code-input:focus { border-color: #3b9eff; }
  .modal-actions { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
  .btn-confirm { flex: 1; padding: 0.75rem; border-radius: 10px; border: none; cursor: pointer; font-weight: 700; font-size: 0.95rem; background: #1565c0; color: #e3f2fd; transition: all 0.2s; }
  .btn-confirm:hover:not(:disabled) { background: #1976d2; }
  .btn-confirm:disabled { background: #0b2440; color: #2a5f8f; cursor: not-allowed; }
  .btn-cancel  { padding: 0.75rem 1.25rem; border-radius: 10px; border: 1px solid #0b3a6e; cursor: pointer; font-weight: 600; font-size: 0.9rem; background: #030f1e; color: #3a6e99; transition: all 0.2s; }
  .btn-cancel:hover { background: #041829; color: #7ec8ff; }
  .msg-error   { margin-top: 0.75rem; padding: 0.6rem 0.9rem; background: #1a0505; border: 1px solid #4a1010; border-radius: 8px; font-size: 0.82rem; color: #ef9a9a; }
  .msg-success { margin-top: 0.75rem; padding: 0.6rem 0.9rem; background: #052e16; border: 1px solid #1b5e20; border-radius: 8px; font-size: 0.82rem; color: #4caf50; }

  /* ── Viewer PDF ── */
  .pdf-modal-backdrop { position: fixed; inset: 0; background: rgba(2,11,21,0.92); z-index: 999; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding: 1.5rem; }
  .pdf-modal { width: 100%; max-width: 900px; height: calc(100vh - 3rem); display: flex; flex-direction: column; background: #020d1a; border: 1px solid #0b3a6e; border-radius: 14px; overflow: hidden; }
  .pdf-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.25rem; background: #030f1f; border-bottom: 1px solid #0b2440; flex-shrink: 0; }
  .pdf-modal-title  { font-size: 0.92rem; font-weight: 600; color: #e8f4ff; display: flex; align-items: center; gap: 0.5rem; }
  .pdf-modal-actions { display: flex; gap: 0.5rem; align-items: center; }
  .btn-close { background: #1a0505; color: #ef9a9a; border: 1px solid #4a1010; border-radius: 7px; padding: 0.35rem 0.75rem; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .btn-close:hover { background: #2d0a0a; }
  .pdf-iframe { flex: 1; width: 100%; border: none; background: #fff; }
</style>

<!-- ═══════════════════════════════════════════════════════════
     HTML
═══════════════════════════════════════════════════════════ -->
<div class="dash">

  <!-- Header -->
  <header class="header">
    <div class="logo">Open<span>TutorAI</span></div>
    {#if $user}
      <span class="user-badge">🎓 {$user.name}</span>
    {/if}
  </header>

  <div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar">
      {#each [
        { id: 'assignments', icon: '📋', label: 'Mes Devoirs' },
        { id: 'courses',     icon: '📚', label: 'Mes Cours'   },
      ] as tab}
        <div
          class="nav-item {activeTab === tab.id ? 'active' : ''}"
          on:click={() => activeTab = tab.id}
          role="button"
          tabindex="0"
        >
          {tab.icon} {tab.label}
        </div>
      {/each}
      <div class="nav-divider"></div>
      <button class="btn-join-sidebar" on:click={() => showJoinModal = true}>
        ➕ Rejoindre une classe
      </button>
    </aside>

    <!-- Contenu principal -->
    <main class="main">

      {#if loading}
        <div class="spin">⏳ Chargement...</div>

      <!-- ══════════════ DEVOIRS ══════════════ -->
      {:else if activeTab === 'assignments'}
        <div class="page-header">
          <div>
            <div class="page-title">Mes Devoirs</div>
            <div class="page-sub">{assignments.length} devoir(s) disponible(s)</div>
          </div>
          {#if classrooms.length === 0}
            <button class="btn btn-join-main" on:click={() => showJoinModal = true}>
              ➕ Rejoindre une classe
            </button>
          {/if}
        </div>

        {#if $user}
          <div class="welcome">
            Bonjour <strong>{$user.name}</strong> 👋 — Voici vos devoirs à rendre.
          </div>
        {/if}

        <div class="stats">
          <div class="stat">
            <div class="stat-num">{assignments.length}</div>
            <div class="stat-label">Total</div>
          </div>
          <div class="stat">
            <div class="stat-num">{assignments.filter(a => a.status === 'active').length}</div>
            <div class="stat-label">Actifs</div>
          </div>
          <div class="stat">
            <div class="stat-num">{assignments.filter(a => (a.submission_count || 0) > 0).length}</div>
            <div class="stat-label">Soumis</div>
          </div>
          <div class="stat">
            <div class="stat-num">
              {assignments.filter(a => {
                const d = Math.ceil((new Date(a.due_date).getTime() - Date.now()) / 86400000);
                return d >= 0 && d <= 3;
              }).length}
            </div>
            <div class="stat-label">Urgents</div>
          </div>
        </div>

        {#if assignments.length === 0}
          <div class="empty">
            📋<br>
            {classrooms.length === 0
              ? 'Rejoignez une classe pour voir vos devoirs.'
              : 'Aucun devoir disponible pour le moment.'}
          </div>
        {:else}
          {#each assignments as a}
            <div class="acard">
              <div class="ainfo">
                <div class="atitle">{a.title}</div>
                {#if a.description}
                  <div style="font-size:0.8rem;color:#4a7fa8;margin:0.2rem 0">{a.description}</div>
                {/if}
                <div class="ameta">
                  {#if a.course}<span>📚 {a.course}</span>{/if}
                  <span>📅 {a.due_date}{a.due_time ? ' à ' + a.due_time : ''}</span>
                  <span>⏰ {getDaysLeft(a.due_date)}</span>
                  <span>⭐ {a.points} pts</span>
                </div>
              </div>
              <span class="deadline {getDaysClass(a.due_date)}">{getDaysLeft(a.due_date)}</span>
              <button
                class="btn btn-submit"
                disabled={getDaysClass(a.due_date) === 'expired'}
              >
                {getDaysClass(a.due_date) === 'expired' ? 'Expiré' : '📤 Soumettre'}
              </button>
            </div>
          {/each}
        {/if}

      <!-- ══════════════ COURS ══════════════ -->
      {:else if activeTab === 'courses'}
        <div class="page-header">
          <div>
            <div class="page-title">Mes Cours</div>
            <div class="page-sub">{courses.length} cours disponible(s)</div>
          </div>
          {#if classrooms.length === 0}
            <button class="btn btn-join-main" on:click={() => showJoinModal = true}>
              ➕ Rejoindre une classe
            </button>
          {/if}
        </div>

        <!-- Stats cours -->
        <div class="stats">
          <div class="stat">
            <div class="stat-num">{courses.length}</div>
            <div class="stat-label">Total</div>
          </div>
          <div class="stat">
            <div class="stat-num">
              {courses.filter(c => c.file_type === '.pdf').length}
            </div>
            <div class="stat-label">PDF</div>
          </div>
          <div class="stat">
            <div class="stat-num">
              {[...new Set(courses.map(c => c.module))].length}
            </div>
            <div class="stat-label">Modules</div>
          </div>
          <div class="stat">
            <div class="stat-num">{courses.length}</div>
            <div class="stat-label">Actifs</div>
          </div>
        </div>

        {#if courses.length === 0}
          <div class="empty">
            📚<br>
            {classrooms.length === 0
              ? 'Rejoignez une classe pour voir vos cours.'
              : 'Aucun cours disponible. Votre professeur n\'a pas encore uploadé de cours.'}
          </div>
        {:else}
          <div class="courses-grid">
            {#each courses as c}
              <div class="ccard">

                <!-- Icône + badge module -->
                <div style="display:flex;align-items:center;justify-content:space-between">
                  <span class="course-icon">{fileIcon(c.file_type)}</span>
                  {#if c.module}
                    <span class="badge-module">{c.module}</span>
                  {/if}
                </div>

                <!-- Titre et description -->
                <div class="course-name">{c.title}</div>
                {#if c.description}
                  <div class="course-desc">{c.description}</div>
                {/if}

                <!-- Métadonnées -->
                <div class="course-meta">
                  <span>📦 {formatSize(c.file_size)}</span>
                  <span>👤 {c.teacher_name || 'Enseignant'}</span>
                  {#if c.file_type}
                    <span>🗂 {c.file_type.replace('.', '').toUpperCase()}</span>
                  {/if}
                </div>

                <!-- Actions -->
                <div class="course-actions">
                  {#if c.file_type === '.pdf'}
                    <button
                      class="btn btn-pdf"
                      style="flex:1"
                      on:click={() => openPdf(getCourseFileUrl(c), c.title)}
                    >
                      👁️ Lire
                    </button>
                  {/if}
                  <button
                    class="btn btn-dl"
                    style="{c.file_type !== '.pdf' ? 'flex:1' : ''}"
                    on:click={() => downloadFile(getCourseFileUrl(c), c.original_filename || c.title)}
                  >
                    ⬇️ Télécharger
                  </button>
                </div>

              </div>
            {/each}
          </div>
        {/if}
      {/if}

    </main>
  </div>
</div>

<!-- ══════════════ MODAL Rejoindre une classe ══════════════ -->
{#if showJoinModal}
  <div
    class="modal-backdrop"
    on:click|self={() => { showJoinModal = false; joinError = ''; joinCode = ''; }}
  >
    <div class="modal">
      <div class="modal-title">🏫 Rejoindre une classe</div>
      <div class="modal-sub">Entrez le code donné par votre professeur</div>
      <input
        class="code-input"
        type="text"
        bind:value={joinCode}
        placeholder="ex: AB3K9Z"
        maxlength="10"
        on:keydown={(e) => e.key === 'Enter' && joinClassroom()}
      />
      {#if joinError}  <div class="msg-error">❌ {joinError}</div>   {/if}
      {#if joinSuccess}<div class="msg-success">{joinSuccess}</div>  {/if}
      <div class="modal-actions">
        <button class="btn-cancel"  on:click={() => { showJoinModal = false; joinError = ''; joinCode = ''; }}>
          Annuler
        </button>
        <button class="btn-confirm" on:click={joinClassroom} disabled={joinLoading}>
          {joinLoading ? '⏳ En cours...' : '✅ Rejoindre'}
        </button>
      </div>
    </div>
  </div>
{/if}

<!-- ══════════════ MODAL Viewer PDF ══════════════ -->
{#if selectedPdf}
  <div class="pdf-modal-backdrop" on:click|self={closePdf}>
    <div class="pdf-modal">
      <div class="pdf-modal-header">
        <div class="pdf-modal-title">📄 {selectedPdf.title}</div>
        <div class="pdf-modal-actions">
          <button
            class="btn btn-dl"
            on:click={() => downloadFile(selectedPdf.url, selectedPdf.title + '.pdf')}
          >
            ⬇️ Télécharger
          </button>
          <button class="btn-close" on:click={closePdf}>✕ Fermer</button>
        </div>
      </div>
      <iframe
        class="pdf-iframe"
        src="{selectedPdf.url}#toolbar=1&navpanes=0"
        title={selectedPdf.title}
      ></iframe>
    </div>
  </div>
{/if}